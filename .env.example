# API (apps/api) — copy to apps/api/.env (Midway dev cwd is apps/api)
API_PORT=7001
JWT_SECRET=change-me-in-production
# sqljs file path (default: apps/api/data/desk.sqljs if unset)
# DATABASE_PATH=./data/desk.sqljs
# Optional: redis://127.0.0.1:6379 — if unset, in-memory store is used for locks/rate limits
REDIS_URL=

# Web (apps/web) and Admin (apps/admin) — put in each app’s .env; Vite requires VITE_ prefix
VITE_API_BASE=/api
# Dev proxy target when running Vite (default in vite.config: http://127.0.0.1:7001)
# VITE_API_PROXY_TARGET=http://127.0.0.1:7001
