# API (apps/api) — copy to apps/api/.env or root .env
API_PORT=7001
JWT_SECRET=change-me-in-production
DATABASE_URL=sqlite:./data/desk.sqlite
# Optional: redis://127.0.0.1:6379 — if unset, in-memory store is used for locks/rate limits
REDIS_URL=

# Web (apps/web) — Vite env must be prefixed with VITE_
VITE_API_BASE=/api
